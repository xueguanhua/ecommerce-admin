# 腾讯云 CloudBase 配置
# 请在云开发控制台获取以下信息

# 环境 ID（在云开发控制台 -> 环境设置中查看）
NEXT_PUBLIC_TCB_ENV_ID=myminicloud-8g3t4rmu223f4356

# 地域（ap-shanghai, ap-guangzhou, ap-singapore 等）
NEXT_PUBLIC_TCB_REGION=ap-shanghai

# 微信公众号 AppID（用于微信登录，可选）
NEXT_PUBLIC_WECHAT_APP_ID=your-app-id

# 微信公众号 AppSecret（用于微信登录，可选）
WECHAT_APP_SECRET=your-app-secret

# 微信开放平台网站应用配置（用于PC端扫码登录，可选）
NEXT_PUBLIC_WECHAT_OPEN_APP_ID=your-open-app-id
WECHAT_OPEN_APP_SECRET=your-open-app-secret
