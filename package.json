{
  "name": "ecommerce-admin",
  "version": "0.1.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "electron": "electron .",
    "electron-dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "download-node": "node scripts/download-node.js",
    "download-node:current": "node scripts/download-node.js --current",
    "check-node": "node scripts/check-node.js",
    "prepack": "npm run check-node",
    "pack": "next build && electron-builder"
  },
  "dependencies": {
    "@cloudbase/js-sdk": "^2.26.3",
    "@cloudbase/node-sdk": "^3.18.1",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-toast": "^1.1.5",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "lucide-react": "^0.312.0",
    "next": "14.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.12.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.2.1",
    "tcb-router": "^1.1.2",
    "wx-server-sdk": "^2.6.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.ecommerce.admin",
    "productName": "电商管理平台",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "next.config.js",
      "package.json",
      ".env.local",
      "resources/**",
      {
        "from": ".next/standalone",
        "to": ".",
        "filter": ["**/*"]
      },
      {
        "from": ".next/static",
        "to": ".next/static",
        "filter": ["**/*"]
      },
      {
        "from": "public",
        "to": "public",
        "filter": ["**/*"]
      }
    ],
    "asar": false,
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.business"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
